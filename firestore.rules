rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerified() && request.auth.token.email == 'sflove087@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'address', 'mobile', 'jomirPoriman', 'amount', 'expireDate', 'pwrBalance', 'chukirdharirName']) &&
               data.name is string && data.name.size() <= 200 &&
               data.address is string && data.address.size() <= 500 &&
               data.mobile is string && data.mobile.size() <= 20 &&
               data.jomirPoriman is string && data.jomirPoriman.size() <= 100 &&
               data.amount is number &&
               data.expireDate is string && data.expireDate.size() <= 64 &&
               data.pwrBalance is number &&
               data.chukirdharirName is string && data.chukirdharirName.size() <= 200 &&
               (!data.keys().contains('isActive') || data.isActive is bool) &&
               (!data.keys().contains('withdrawals') || data.withdrawals is list);
      }

      allow read: if isVerified();
      allow create: if isVerified() && isValidUser(request.resource.data);
      allow update: if isVerified() && (
        // Action: Edit Profile
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'address', 'mobile', 'jomirPoriman', 'amount', 'expireDate', 'pwrBalance', 'chukirdharirName', 'isActive', 'withdrawals']) && isValidUser(request.resource.data)) ||
        // Action: Toggle Status (isActive)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActive']) &&
         request.resource.data.isActive is bool) ||
        // Action: Withdrawal (amount and withdrawals list change)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amount', 'withdrawals']) &&
         request.resource.data.amount is number &&
         request.resource.data.withdrawals is list) ||
        // Action: Collect / Extend
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expireDate', 'pwrBalance', 'history']) && 
         request.resource.data.expireDate is string &&
         request.resource.data.pwrBalance is number &&
         request.resource.data.history is list)
      );
      allow delete: if isVerified();

      match /history/{historyId} {
        allow read, write: if isVerified();
      }
    }
  }
}
