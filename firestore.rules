rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['name', 'address', 'mobile', 'jomirPoriman', 'amount', 'expireDate', 'pwrBalance', 'chukirdharirName']) &&
               data.name is string && data.name.size() <= 200 &&
               data.address is string && data.address.size() <= 500 &&
               data.mobile is string && data.mobile.size() <= 20 &&
               data.jomirPoriman is string && data.jomirPoriman.size() <= 100 &&
               data.amount is number && data.amount >= 0 &&
               data.expireDate is string && data.expireDate.size() <= 20 &&
               data.pwrBalance is number &&
               data.chukirdharirName is string && data.chukirdharirName.size() <= 200;
      }

      function isVerified() {
        return isSignedIn() && request.auth.token.email_verified == true;
      }

      allow read: if isVerified();
      allow create: if isVerified() && isValidUser(request.resource.data);
      allow update: if isVerified() && (
        // Action: Edit Profile
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'address', 'mobile', 'jomirPoriman', 'amount', 'expireDate', 'pwrBalance', 'chukirdharirName']) && isValidUser(request.resource.data)) ||
        // Action: Collect / Extend
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expireDate', 'pwrBalance', 'history']) && 
         request.resource.data.expireDate is string &&
         request.resource.data.pwrBalance is number &&
         request.resource.data.history is list)
      );
      allow delete: if isVerified();

      // Legacy history subcollection rule (kept for safety if we migrate later)
      match /history/{historyId} {
        allow read, write: if isVerified();
      }
    }
  }
}
